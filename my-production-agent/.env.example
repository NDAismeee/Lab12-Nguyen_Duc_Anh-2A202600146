PORT=8000
HOST=0.0.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# Comma-separated API keys (or single AGENT_API_KEY) allowed to call /ask
AGENT_API_KEYS=change-me

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Redis
REDIS_URL=redis://localhost:6379/0

# Rate limiting
RATE_LIMIT_PER_MINUTE=10

# Monthly budget guard
MONTHLY_BUDGET_USD=10

